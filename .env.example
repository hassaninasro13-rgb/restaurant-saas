# Copy to `.env` at the repo root. `npm run build` reads it and writes `supabase/runtime-config.js`.
# On Vercel: set the same keys under Project → Settings → Environment Variables for Production *and* Preview.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
